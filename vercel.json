{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npx next build",
  "outputDirectory": ".next",
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "crons": [
    {
      "path": "/api/cron/heartbeat",
      "schedule": "50 0 * * *"
    },
    {
      "path": "/api/cron/evaluate-tripwires",
      "schedule": "*/5 * * * *"
    }
  ]
}
